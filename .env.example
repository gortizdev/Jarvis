# ============================
# Enhanced Voice Assistant Configuration
# ============================
# Copy this file to .env and configure your settings

# ============================
# Required API Keys
# ============================
OPENAI_API_KEY=sk-your-openai-api-key
PICOVOICE_ACCESS_KEY=your-picovoice-access-key

# ============================
# Home Assistant
# ============================
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your-long-lived-access-token

# Entity/state cache TTL (seconds)
HA_CACHE_TTL=60
HA_AREAS_CACHE_TTL=300

# ============================
# Audio Configuration
# ============================
# Microphone device index (use `python -c "import sounddevice; print(sounddevice.query_devices())"`)
MIC_DEVICE_INDEX=2
MIC_RATE=48000

# ALSA output device for playback (use `aplay -l` to list devices)
ALSA_DEVICE=default

# WebRTC VAD mode (0-3, higher = more aggressive speech detection)
VAD_MODE=3

# Recording parameters
MAX_UTTERANCE_SECONDS=15.0
SILENCE_RMS_THRESHOLD=0.012
SILENCE_SECONDS_TO_STOP=0.75
MIN_SPEECH_SECONDS=0.4
LEADING_SILENCE_TIMEOUT=4.0
ADAPTIVE_THRESHOLD_MULT=2.5
NOISE_CALIBRATION_FRAMES=10

# Noise reduction (requires noisereduce library)
NOISE_REDUCE_ENABLED=true

# ============================
# Wake Word Configuration
# ============================
# Built-in wake words: alexa, americano, blueberry, bumblebee, computer, 
# grapefruit, grasshopper, hey barista, hey google, hey siri, jarvis, 
# ok google, picovoice, pico clock, porcupine, terminator
WAKE_WORD=picovoice

# Or use custom .ppn file
# PORCUPINE_KEYWORD_PATH=hey-jarvis.ppn

# Wake word sensitivity (0.0 - 1.0)
WAKE_SENSITIVITY=0.65

# ============================
# OpenAI Models
# ============================
CHAT_MODEL=gpt-4o
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=fable

# TTS Settings
TTS_STREAMING=true
TTS_VOLUME_NORM=true
TTS_TARGET_DB=-20.0

# ============================
# Conversation Settings
# ============================
MAX_HISTORY_MESSAGES=30
MAX_TOOL_ROUNDS=5

# Follow-up mode: listen briefly after response without requiring wake word
FOLLOWUP_ENABLED=true
FOLLOWUP_WINDOW_SECONDS=5.0
FOLLOWUP_SILENCE_TIMEOUT=2.0

# Barge-in: allow interrupting TTS with wake word
BARGEIN_ENABLED=true

# Custom system prompt (optional - leave empty for default)
SYSTEM_PROMPT=

# ============================
# Sound Effects
# ============================
SFX_ENABLED=true
SFX_STYLE=jarvis
SFX_VOLUME=0.55

# Sound effect WAV files (optional paths)
SFX_AFTER_WAKE_WAV=
SFX_AFTER_QUESTION_WAV=
SFX_SUCCESS_WAV=
SFX_FAILURE_WAV=
SFX_LISTENING_WAV=

# ============================
# Health Monitoring
# ============================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60

# Watchdog: auto-detect and recover from hangs
WATCHDOG_ENABLED=true
WATCHDOG_TIMEOUT=120

# ============================
# API Retry Settings
# ============================
API_MAX_RETRIES=3
API_RETRY_BASE_DELAY=1.0

# ============================
# Debug Settings
# ============================
LOG_LEVEL=INFO
DEBUG_TOOLS=false
DEBUG_HA=false
